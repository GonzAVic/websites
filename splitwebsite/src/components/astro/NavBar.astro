---
import Button from './Button.astro'
import Container from './Container.astro'
import { CHROME_STORE_URL } from '../../content/links'
import { withBase } from '../../utils/paths'
---

<header class="sticky top-0 z-50 border-b border-brand-border bg-brand-bg/80 backdrop-blur">
  <Container class="flex items-center justify-between py-4">
    <a href={withBase('/')} class="font-black tracking-widest text-brand-heading">SPLIT</a>
    <nav class="hidden items-center gap-6 text-sm text-brand-dim sm:flex">
      <a href={withBase('/#how-it-works')} class="hover:text-brand-heading">How it works</a>
      <a href={withBase('/#features')} class="hover:text-brand-heading">Features</a>
      <a href={withBase('/#faq')} class="hover:text-brand-heading">FAQ</a>
    </nav>
    <Button href={CHROME_STORE_URL} target="_blank" rel="noopener noreferrer" size="sm">
      Add to Chrome
    </Button>
  </Container>
</header>
