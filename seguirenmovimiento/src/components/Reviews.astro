---
import { getContent } from "../data";

const { reviews, site, ui } = getContent(Astro.currentLocale);
const totalReviews = site.rating.breakdown.reduce((sum, b) => sum + b.count, 0);
---

<section id="resenas" class="mx-auto max-w-6xl scroll-mt-24 px-5 py-20 sm:px-8">
  <div class="mb-10 flex flex-wrap items-end justify-between gap-4">
    <div>
      <span class="text-sm font-semibold uppercase tracking-wide text-brand-600"
        >{ui.reviews.eyebrow}</span
      >
      <h2 class="mt-2 font-display text-2xl font-bold text-ink sm:text-3xl">
        {ui.reviews.heading}
      </h2>
    </div>
  </div>

  <div class="mb-12 grid gap-8 rounded-3xl border border-line bg-surface p-6 shadow-card sm:p-8 lg:grid-cols-[auto_1fr] lg:items-center">
    <div class="flex flex-col items-center gap-2 lg:border-r lg:border-line lg:pr-8">
      <span class="font-display text-5xl font-bold text-ink"
        >{site.rating.average.toFixed(1)}</span
      >
      <div class="flex gap-0.5 text-accent-500">
        {
          Array.from({ length: 5 }).map(() => (
            <svg viewBox="0 0 20 20" fill="currentColor" class="h-4 w-4">
              <path d="M10 1.5l2.6 5.6 6.1.7-4.5 4.1 1.2 6-5.4-3-5.4 3 1.2-6-4.5-4.1 6.1-.7z" />
            </svg>
          ))
        }
      </div>
      <span class="text-sm text-ink-soft">{site.rating.count} {ui.reviewsWord}</span>
    </div>

    <div class="flex flex-col gap-2">
      {
        site.rating.breakdown.map((row) => (
          <div class="flex items-center gap-3">
            <span class="w-4 text-xs font-medium text-ink-soft">{row.stars}</span>
            <div class="h-1.5 flex-1 overflow-hidden rounded-full bg-canvas-soft">
              <div
                class="h-full rounded-full bg-accent-500"
                style={`width: ${totalReviews ? (row.count / totalReviews) * 100 : 0}%`}
              />
            </div>
            <span class="w-6 text-right text-xs font-medium text-ink-soft">
              {row.count}
            </span>
          </div>
        ))
      }
    </div>
  </div>

  <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
    {
      reviews.map((review) => (
        <article class="flex flex-col gap-3 rounded-2xl border border-line bg-surface p-6 shadow-card">
          <div class="flex items-center justify-between">
            <span class="font-display text-sm font-semibold text-ink">
              {review.author}
            </span>
            <span class="text-xs text-ink-soft">{review.timeAgo}</span>
          </div>
          <div class="flex gap-0.5 text-accent-500">
            {Array.from({ length: review.rating }).map(() => (
              <svg viewBox="0 0 20 20" fill="currentColor" class="h-3.5 w-3.5">
                <path d="M10 1.5l2.6 5.6 6.1.7-4.5 4.1 1.2 6-5.4-3-5.4 3 1.2-6-4.5-4.1 6.1-.7z" />
              </svg>
            ))}
          </div>
          <p class="text-sm leading-relaxed text-ink-soft">{review.text}</p>
        </article>
      ))
    }
  </div>
</section>
