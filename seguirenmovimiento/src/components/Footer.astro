---
import { getContent } from "../data";
import { withBase } from "../utils/paths";

const { site, ui } = getContent(Astro.currentLocale);
const year = new Date().getFullYear();
---

<footer class="border-t border-line bg-ink text-canvas-soft">
  <div class="mx-auto flex max-w-6xl flex-col gap-8 px-5 py-14 sm:px-8">
    <div class="flex flex-col items-start gap-6 sm:flex-row sm:items-center sm:justify-between">
      <div class="flex items-center gap-3">
        <img
          src={withBase("/images/logo.png")}
          alt={`${ui.logoAlt} ${site.name}`}
          width="40"
          height="40"
          class="h-10 w-10 rounded-full object-cover ring-2 ring-white/20"
        />
        <div>
          <p class="font-display text-sm font-semibold text-white">
            {site.name}
          </p>
          <p class="text-xs text-canvas-soft/70">{site.address.city}</p>
        </div>
      </div>

      <a
        href={site.bookingUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="rounded-full bg-brand-500 px-6 py-3 text-sm font-semibold text-white transition-colors hover:bg-brand-400"
      >
        {ui.bookAppointment}
      </a>
    </div>

    <div class="flex flex-col gap-4 border-t border-white/10 pt-6 text-xs text-canvas-soft/70 sm:flex-row sm:items-center sm:justify-between">
      <p>© {year} {site.name}. {ui.footer.rights}</p>
      <div class="flex items-center gap-4">
        <a href={`mailto:${site.email}`} class="transition-colors hover:text-white"
          >{site.email}</a
        >
        <a
          href={site.whatsapp}
          target="_blank"
          rel="noopener noreferrer"
          class="transition-colors hover:text-white">{ui.whatsappLabel}</a
        >
      </div>
    </div>
  </div>
</footer>
