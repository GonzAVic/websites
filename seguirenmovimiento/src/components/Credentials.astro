---
import { getContent } from "../data";

const { certifications, publications, skills, ui } = getContent(Astro.currentLocale);
---

<section
  id="credenciales"
  class="mx-auto max-w-6xl scroll-mt-24 px-5 py-20 sm:px-8"
>
  <div class="mb-4 max-w-2xl">
    <span class="text-sm font-semibold uppercase tracking-wide text-brand-600"
      >{ui.credentials.eyebrow}</span
    >
    <h2 class="mt-2 font-display text-2xl font-bold text-ink sm:text-3xl">
      {ui.credentials.heading}
    </h2>
    <p class="mt-3 text-base text-ink-soft">
      {ui.credentials.subheading}
    </p>
  </div>

  <div class="mb-8 inline-flex items-center gap-2 rounded-full border border-accent-200 bg-accent-50 px-4 py-2 text-xs font-medium text-accent-600">
    <svg viewBox="0 0 24 24" fill="none" class="h-3.5 w-3.5 shrink-0">
      <path
        d="M12 9v4m0 4h.01M4.93 4.93a10 10 0 1 1 14.14 14.14A10 10 0 0 1 4.93 4.93Z"
        stroke="currentColor"
        stroke-width="1.8"
        stroke-linecap="round"
        stroke-linejoin="round"></path>
    </svg>
    {ui.credentials.mockNotice}
  </div>

  <div class="grid gap-5 lg:grid-cols-3">
    <div class="flex flex-col gap-5 rounded-2xl border border-line bg-surface p-6 shadow-card">
      <div class="flex items-center gap-2.5">
        <span class="flex h-9 w-9 items-center justify-center rounded-full bg-brand-50 text-lg"
          >🎓</span
        >
        <h3 class="font-display text-base font-semibold text-ink">
          {ui.credentials.certifications}
        </h3>
      </div>
      <ul class="flex flex-col gap-4">
        {
          certifications.map((cert) => (
            <li class="border-l-2 border-brand-200 pl-4">
              <p class="text-sm font-semibold leading-snug text-ink">
                {cert.title}
              </p>
              <p class="mt-0.5 text-xs text-ink-soft">
                {cert.issuer} · {cert.year}
              </p>
            </li>
          ))
        }
      </ul>
    </div>

    <div class="flex flex-col gap-5 rounded-2xl border border-line bg-surface p-6 shadow-card">
      <div class="flex items-center gap-2.5">
        <span class="flex h-9 w-9 items-center justify-center rounded-full bg-brand-50 text-lg"
          >🧠</span
        >
        <h3 class="font-display text-base font-semibold text-ink">
          {ui.credentials.skills}
        </h3>
      </div>
      <div class="flex flex-wrap gap-2">
        {
          skills.map((skill) => (
            <span class="rounded-full bg-canvas-soft px-3 py-1.5 text-xs font-medium text-ink-soft">
              {skill}
            </span>
          ))
        }
      </div>
    </div>

    <div class="flex flex-col gap-5 rounded-2xl border border-line bg-surface p-6 shadow-card">
      <div class="flex items-center gap-2.5">
        <span class="flex h-9 w-9 items-center justify-center rounded-full bg-brand-50 text-lg"
          >📚</span
        >
        <h3 class="font-display text-base font-semibold text-ink">
          {ui.credentials.publications}
        </h3>
      </div>
      <ul class="flex flex-col gap-4">
        {
          publications.map((pub) => (
            <li class="border-l-2 border-brand-200 pl-4">
              <p class="text-sm font-semibold leading-snug text-ink">
                {pub.title}
              </p>
              <p class="mt-0.5 text-xs text-ink-soft">
                {pub.venue} · {pub.year}
              </p>
            </li>
          ))
        }
      </ul>
    </div>
  </div>
</section>
