---
import "../styles/global.css";
import { getRelativeLocaleUrl } from "astro:i18n";
import { locales } from "../data";
import { withBase } from "../utils/paths";

interface Props {
  title: string;
  description: string;
}

const { title, description } = Astro.props;
const locale = Astro.currentLocale ?? "es";

// Ruta actual sin el `base` del sitio ni el prefijo de idioma (en/),
// para reconstruir el equivalente en cada idioma con getRelativeLocaleUrl.
const base = import.meta.env.BASE_URL;
let localeAgnosticPath = Astro.url.pathname;
if (localeAgnosticPath.startsWith(base)) {
  localeAgnosticPath = localeAgnosticPath.slice(base.length);
}
localeAgnosticPath = localeAgnosticPath.replace(/^en\/?/, "");
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/png" href={withBase("/images/logo.png")} />
    <title>{title}</title>
    <meta name="description" content={description} />

    {
      locales.map((loc) => (
        <link
          rel="alternate"
          hreflang={loc}
          href={getRelativeLocaleUrl(loc, localeAgnosticPath)}
        />
      ))
    }

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Manrope:wght@600;700;800&display=swap"
      rel="stylesheet"
    />

    <noscript>
      <style>
        [data-reveal] {
          opacity: 1 !important;
          transform: none !important;
        }
      </style>
    </noscript>
  </head>
  <body>
    <slot />
    <script src="../scripts/reveal.ts"></script>
  </body>
</html>
